<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:orientation="vertical">

    <!-- Row: type label + numbers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Leave Type Label -->
        <TextView
            android:id="@+id/tv_leave_type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/colorPrimaryDark"
            android:textSize="13sp"
            tools:text="Annual Leave" />

        <!-- credited -->
        <TextView
            android:id="@+id/tv_credited"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="20" />

        <!-- Opening -->
        <TextView
            android:id="@+id/tv_opening"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="20" />

        <!-- Used -->
        <TextView
            android:id="@+id/tv_used"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/leave_used"
            android:textSize="13sp"
            tools:text="8" />

        <!-- Balance (credited - used) -->
        <TextView
            android:id="@+id/tv_balance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/leave_balance_positive"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="12" />

    </LinearLayout>

    <!-- Progress bar for visual leave usage -->
    <ProgressBar
        android:id="@+id/pb_leave_usage"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="6dp"
        android:max="100"
        android:progress="40"
        android:progressDrawable="@drawable/progress_leave"
        tools:progress="40" />

</LinearLayout>