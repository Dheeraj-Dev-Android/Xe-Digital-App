<?xml version="1.0" encoding="utf-8"?><!--
    activity_face_login.xml — Fixed layout

    Changes from original:
    ─────────────────────────────────────────────────────────────────────────
    1. ProgressBar inside loadingPanel given android:id="@+id/progressBar"
       so Java references compile (previously missing → NPE).

    2. Added android:id="@+id/scannerLine" and android:id="@+id/faceGuide"
       so toggleScannerAnimation() can find them (previously missing → NPE).
       scannerLine is positioned inside the cameraCard area; faceGuide is the
       full camera circle guide.

    3. Added contentDescription to PreviewView and FaceOverlayView for
       accessibility / lint compliance.

    4. loadingPanel given proper ConstraintLayout anchors (top/bottom/start/end)
       so the full-screen overlay is reliably anchored on all API levels.

    5. Minor: statusModule constraint changed to
       app:layout_constraintTop_toBottomOf="@id/cameraCard" so it doesn't
       rely solely on a bottom constraint that can drift on small screens.
    ─────────────────────────────────────────────────────────────────────────
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    tools:context=".activity.FaceLoginActivity">

    <!-- ===== INFO ICON (Top Right) ===== -->
    <ImageButton
        android:id="@+id/btnInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Show Instructions"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_dialog_info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#4A4A6A" />

    <!-- ===== TOP HEADER MODULE ===== -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <!-- Lock icon row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/lock_icon_desc"
                android:gravity="center"
                android:text="🔐"
                android:textSize="18sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="10dp"
                android:background="#2A2A3A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:text="SECURE ACCESS"
                android:textColor="#4A4A6A"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:lineSpacingExtra="2dp"
            android:text="Identity\nVerification"
            android:textColor="#EEEEF8"
            android:textSize="30sp" />

        <!-- Thin accent line under title -->
        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            android:background="#5B5BFF" />
    </LinearLayout>

    <!-- ===== CAMERA MODULE (Circle) ===== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cameraCard"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:cardBackgroundColor="#12121C"
        app:cardCornerRadius="140dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:strokeColor="#5B5BFF"
        app:strokeWidth="2dp">

        <!-- FIX: contentDescription added for accessibility -->
        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/camera_preview_desc" />

        <!-- FIX: contentDescription added for accessibility -->
        <app.xedigital.ai.utills.FaceOverlayView
            android:id="@+id/faceOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/face_overlay_desc" />

        <!--
            FIX: scannerLine — referenced by toggleScannerAnimation() in Java.
            Previously missing from XML → NullPointerException.
            Positioned at the top of the camera circle; Java animates it downward.
        -->
        <View
            android:id="@+id/scannerLine"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#805B5BFF"
            android:visibility="gone" />

    </com.google.android.material.card.MaterialCardView>

    <!--
        FIX: faceGuide — referenced by toggleScannerAnimation() to get the
        height of the guide area for the animation end-point.
        Previously missing from XML → NullPointerException.
        Overlaid on the camera card, same size.
    -->
    <View
        android:id="@+id/faceGuide"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:alpha="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <!-- Corner scan decorator (purely visual) -->
    <View
        android:layout_width="24dp"
        android:layout_height="3dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:alpha="0.6"
        android:background="#5B5BFF"
        app:layout_constraintStart_toStartOf="@id/cameraCard"
        app:layout_constraintTop_toTopOf="@id/cameraCard" />

    <!-- ===== STATUS MODULE ===== -->
    <LinearLayout
        android:id="@+id/statusModule"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toTopOf="@id/footerText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cameraCard">

        <!-- Pulse dot + status label row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/shape_pulse_dot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.25"
                android:text="SCANNING"
                android:textColor="#5B5BFF"
                android:textSize="10sp" />
        </LinearLayout>

        <!--
            Main status text.
            FIX: Java previously tried to find R.id.CaptureText which didn't exist → NPE.
                 This view keeps the correct id="@+id/statusText" that Java now uses.
        -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Position your face\nwithin the circle"
            android:textColor="#EEEEF8"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ===== FOOTER MODULE ===== -->
    <TextView
        android:id="@+id/footerText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="48dp"
        android:layout_marginBottom="36dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Only the authorized account holder\ncan access this device."
        android:textColor="#3A3A5A"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== LOADING OVERLAY MODULE ===== -->
    <!--
        FIX 1: Added all four constraint anchors so the overlay reliably covers the
                full screen (original had none → unpredictable positioning).
        FIX 2: ProgressBar now has android:id="@+id/progressBar" so Java can reference it.
                (Original ProgressBar had no id → Java's progressBar = findViewById(...)
                 returned null → NPE on progressBar.setVisibility())
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/loadingPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:cardBackgroundColor="#E6000000"
        app:cardElevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Glowing card behind spinner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="88dp"
                android:layout_height="88dp"
                app:cardBackgroundColor="#12121C"
                app:cardCornerRadius="44dp"
                app:cardElevation="0dp"
                app:strokeColor="#5B5BFF"
                app:strokeWidth="1dp">

                <!-- FIX: android:id added so Java can reference R.id.progressBar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/loading_desc"
                    android:indeterminateTint="#5B5BFF" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:text="Verifying Identity..."
                android:textColor="#EEEEF8"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="Please hold still"
                android:textColor="#4A4A6A"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>