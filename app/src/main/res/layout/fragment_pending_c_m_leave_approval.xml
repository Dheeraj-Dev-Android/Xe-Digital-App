<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".ui.leaves.PendingCMLeaveApprovalFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Employee Details"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/empName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Test Emp"
                        android:textColor="@color/primary_text"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/empEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="abed.e@consultedge.global"
                        android:textColor="@color/secondary_text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/empDesignation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Software Analyst"
                        android:textColor="@color/secondary_text"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/titleLeaveDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Leave Details"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.divider.MaterialDivider
                        android:id="@+id/dividerLeave"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/titleLeaveDetails" />

                    <TextView
                        android:id="@+id/lblLeaveType"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Leave Name:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empLeaveType"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dividerLeave" />

                    <TextView
                        android:id="@+id/empLeaveType"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Casual Leave"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblLeaveType"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblLeaveType" />

                    <TextView
                        android:id="@+id/lblFromDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="From Date:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empFromDate"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/empLeaveType" />

                    <TextView
                        android:id="@+id/empFromDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="21 Nov 2024"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblFromDate"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblFromDate" />

                    <TextView
                        android:id="@+id/lblTypeFrom"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Select Type From:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empSelectTypeFrom"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/empFromDate" />

                    <TextView
                        android:id="@+id/empSelectTypeFrom"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Full Day / Half Day"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblTypeFrom"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblTypeFrom" />

                    <TextView
                        android:id="@+id/lblToDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="To Date:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empToDate"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/empSelectTypeFrom" />

                    <TextView
                        android:id="@+id/empToDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="21 Nov 2024"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblToDate"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblToDate" />

                    <TextView
                        android:id="@+id/lblTypeTo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Select Type To:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empSelectTypeTo"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/empToDate" />

                    <TextView
                        android:id="@+id/empSelectTypeTo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Full Day / Half Day"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblTypeTo"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblTypeTo" />

                    <TextView
                        android:id="@+id/lblAppliedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Applied Date:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empAppliedDate"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/empSelectTypeTo" />

                    <TextView
                        android:id="@+id/empAppliedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="21 Nov 2024"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblAppliedDate"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblAppliedDate" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reason for Leave"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/empReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Testing"
                        android:textColor="@color/primary_text"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Details"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/empContactNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Contact: 2523552561"
                        android:textColor="@color/primary_text"
                        android:textSize="15sp"
                        app:drawableTint="@color/secondary_text" />

                    <TextView
                        android:id="@+id/empAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Address: Testing"
                        android:textColor="@color/primary_text"
                        android:textSize="15sp"
                        app:drawableTint="@color/secondary_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Leaving Station"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/empLeavingStation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Yes / No"
                        android:textColor="@color/primary_text"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vacation Address"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/empVacationAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Street 123, City, State"
                        android:textColor="@color/primary_text"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/titleStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status Details"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.divider.MaterialDivider
                        android:id="@+id/dividerStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/titleStatus" />

                    <TextView
                        android:id="@+id/lblStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Status:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/empStatusChip"
                        app:layout_constraintEnd_toStartOf="@id/empStatusChip"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dividerStatus" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/empStatusChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textColor="@color/white"
                        android:textStyle="bold|italic"
                        app:chipBackgroundColor="@color/error_color"
                        app:layout_constraintStart_toEndOf="@id/lblStatus"
                        app:layout_constraintTop_toBottomOf="@id/dividerStatus" />

                    <TextView
                        android:id="@+id/lblStatusUpdatedBy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Status Updated By:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empStatusUpdatedBy"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/empStatusChip" />

                    <TextView
                        android:id="@+id/empStatusUpdatedBy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="HR Manager"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblStatusUpdatedBy"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblStatusUpdatedBy" />

                    <TextView
                        android:id="@+id/lblStatusUpdatedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Status Updated Date:"
                        android:textColor="@color/secondary_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/empStatusUpdatedDate"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lblStatusUpdatedBy" />

                    <TextView
                        android:id="@+id/empStatusUpdatedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="22 Nov 2024"
                        android:textColor="@color/primary_text"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblStatusUpdatedDate"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1.2"
                        app:layout_constraintStart_toEndOf="@id/lblStatusUpdatedDate" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comments"
                        android:textColor="@color/primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/empComments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No additional comments"
                        android:textColor="@color/primary_text"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/leaveBtnReject"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/RestrictedHoliday"
                    android:text="Reject"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/leaveBtnApprove"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/success_color"
                    android:text="Approve"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/leaveBtnCancel"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/_000000"
                    android:text="Cancel"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>