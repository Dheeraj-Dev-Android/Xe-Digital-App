<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/fragment_dashboard_bg"
        android:fillViewport="true"
        tools:context=".ui.dashboard.DashboardFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingBottom="16dp">


            <ImageView
                android:id="@+id/ivHeaderAvatar"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_circle_tint"
                android:contentDescription="@string/user_profile_picture"
                android:padding="10dp"
                android:src="@mipmap/ic_default_profile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/greeting_default"
                android:textColor="@color/avatar_bg"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivHeaderAvatar"
                app:layout_constraintEnd_toStartOf="@id/tvHeaderEmployeeName"
                app:layout_constraintStart_toEndOf="@id/ivHeaderAvatar"
                app:layout_constraintTop_toTopOf="@id/ivHeaderAvatar" />

            <TextView
                android:id="@+id/tvHeaderEmployeeName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="16dp"
                android:text="Employee Name"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/tvGreeting"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvGreeting" />

            <!-- Shimmer for punch card -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/punchCardShimmer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivHeaderAvatar">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/text_primary"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <View
                            android:layout_width="120dp"
                            android:layout_height="20dp"
                            android:background="@color/primary_text_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="16dp"
                            android:background="@color/primary_text_color" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- Punch card (Updated Layout) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/punchCardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/text_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivHeaderAvatar"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/ivPunchCardBackground"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:alpha="0.3"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:src="@drawable/punch_card_bg" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Left Text Layout Column -->
                    <TextView
                        android:id="@+id/tvPunchStatusLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:letterSpacing="0.03"
                        android:text="@string/current_status"
                        android:textAllCaps="true"
                        android:textColor="@color/avatar_bg"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/punchButton"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvPunchStatusValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:layout_marginEnd="16dp"
                        android:text="@string/not_punched_in"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/punchButton"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPunchStatusLabel" />

                    <!-- Date & Time moved below the Punch Status -->
                    <TextView
                        android:id="@+id/todayDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginBottom="4dp"
                        android:text="20 Feb 2024"
                        android:textColor="@color/colorPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/punchButton"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPunchStatusValue" />

                    <!-- Circular Punch Button moved to the Right Side -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/punchButton"
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:layout_marginRight="20dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/colorPrimary"
                        app:cardCornerRadius="37dp"
                        app:cardElevation="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <ImageView
                                android:id="@+id/ivPunchButtonIcon"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_fingerprint"
                                app:tint="@color/white" />

                            <TextView
                                android:id="@+id/tvPunchButtonLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Punch-In"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick actions shimmer -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/quickActionsShimmer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/punchCardShimmer">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/text_primary"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:weightSum="4">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@color/primary_text_color" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@color/primary_text_color" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@color/primary_text_color" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@color/primary_text_color" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- Quick actions card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/quickActionsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/text_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/punchCardView"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/quick_actions"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <!-- Attendance detail -->
                        <LinearLayout
                            android:id="@+id/btnQuickAttendance"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:background="@drawable/bg_rounded_icon_12"
                                android:backgroundTint="@color/icon_background">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/attendance_detail"
                                    android:src="@drawable/ic_event"
                                    app:tint="@color/icon_tint" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/attendance_detail"
                                android:textColor="@color/avatar_bg"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:ignore="SmallSp" />
                        </LinearLayout>

                        <!-- Apply leave -->
                        <LinearLayout
                            android:id="@+id/btnQuickApplyLeave"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:background="@drawable/bg_rounded_icon_12"
                                android:backgroundTint="@color/bg_tint_green">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/apply_leave"
                                    android:src="@drawable/ic_event_add"
                                    app:tint="@color/PrivilegeLeave" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/apply_leave"
                                android:textColor="@color/avatar_bg"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:ignore="SmallSp" />
                        </LinearLayout>

                        <!-- Add timesheet -->
                        <LinearLayout
                            android:id="@+id/btnQuickTimesheet"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:background="@drawable/bg_rounded_icon_12"
                                android:backgroundTint="@color/warning_bg">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/add_timesheet"
                                    android:src="@drawable/ic_access_time"
                                    app:tint="@color/SickLeave" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/add_timesheet"
                                android:textColor="@color/avatar_bg"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:ignore="SmallSp" />
                        </LinearLayout>

                        <!-- Book meeting -->
                        <LinearLayout
                            android:id="@+id/btnQuickBookMeeting"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:background="@drawable/bg_rounded_icon_12"
                                android:backgroundTint="@color/bg_tint_cyan">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/book_meeting"
                                    android:src="@drawable/ic_videocam"
                                    app:tint="@color/OccasionalLeave" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/book_meeting"
                                android:textColor="@color/avatar_bg"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:ignore="SmallSp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Shimmer for employee card -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/employeeCardShimmer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/quickActionsShimmer">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/text_primary"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/shimmerProfile"
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:background="@color/primary_text_color" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <View
                                    android:layout_width="140dp"
                                    android:layout_height="16dp"
                                    android:background="@color/primary_text_color" />

                                <View
                                    android:layout_width="100dp"
                                    android:layout_height="14dp"
                                    android:layout_marginTop="8dp"
                                    android:background="@color/primary_text_color" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:background="@color/gray_hint" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:layout_marginTop="12dp"
                            android:background="@color/primary_text_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/primary_text_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/primary_text_color" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- Employee card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/employeeCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/text_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/quickActionsCard"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guideline_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.01" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guideline_middle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.3" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/profileBorderContainer"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="29dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="@color/gray_hint"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/ivEmployeeProfile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/user_profile_picture"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_default_profile" />
                    </com.google.android.material.card.MaterialCardView>


                    <TextView
                        android:id="@+id/tvEmployeeNameValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:autoSizePresetSizes="@array/autoSize_text_sizes"
                        android:autoSizeTextType="uniform"
                        android:gravity="center_vertical"
                        android:text="Employee Name"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/profileBorderContainer"
                        app:layout_constraintTop_toTopOf="@id/profileBorderContainer" />

                    <TextView
                        android:id="@+id/tvEmployeeDesignationValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="3dp"
                        android:gravity="center_vertical"
                        android:text="Software Engineer"
                        android:textColor="@color/avatar_bg"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/profileBorderContainer"
                        app:layout_constraintTop_toBottomOf="@id/tvEmployeeNameValue" />

                    <TextView
                        android:id="@+id/tvEmployeeCodeValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="3dp"
                        android:gravity="center_vertical"
                        android:text="CEG 01"
                        android:textColor="@color/avatar_bg"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/profileBorderContainer"
                        app:layout_constraintTop_toBottomOf="@id/tvEmployeeDesignationValue" />

                    <View
                        android:id="@+id/dividerAfterProfile"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:background="@color/gray_hint"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/profileBorderContainer" />

                    <!-- Email row -->
                    <TextView
                        android:id="@+id/tvEmployeeEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:autoSizePresetSizes="@array/autoSize_text_sizes"
                        android:autoSizeTextType="uniform"
                        android:text="Email : "
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dividerAfterProfile" />


                    <TextView
                        android:id="@+id/tvEmployeeEmailValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:autoSizePresetSizes="@array/autoSize_text_sizes"
                        android:autoSizeTextType="uniform"
                        android:text="employee.t@xyz"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="@id/tvEmployeeEmail"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvEmployeeEmail"
                        app:layout_constraintTop_toTopOf="@id/tvEmployeeEmail" />

                    <!-- Contact row -->
                    <TextView
                        android:id="@+id/tvEmployeeContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:autoSizePresetSizes="@array/autoSize_text_sizes"
                        android:autoSizeTextType="uniform"
                        android:text="Contact : "
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvEmployeeEmail" />


                    <TextView
                        android:id="@+id/tvEmployeeContactValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:autoSizePresetSizes="@array/autoSize_text_sizes"
                        android:autoSizeTextType="uniform"
                        android:text="123-456-7890"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="@id/tvEmployeeContact"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvEmployeeContact"
                        app:layout_constraintTop_toTopOf="@id/tvEmployeeContact" />

                    <!-- Shift row -->
                    <TextView
                        android:id="@+id/tvEmployeeShift"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:autoSizePresetSizes="@array/autoSize_text_sizes"
                        android:autoSizeTextType="uniform"
                        android:text="Shift : "
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvEmployeeContact"
                        tools:ignore="MissingConstraints" />

                    <TextView
                        android:id="@+id/tvEmployeeShiftValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:autoSizePresetSizes="@array/autoSize_text_sizes"
                        android:autoSizeTextType="uniform"
                        android:text="9:00 AM - 5:00 PM"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="@id/tvEmployeeShift"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvEmployeeShift"
                        app:layout_constraintTop_toTopOf="@id/tvEmployeeShift" />

                    <View
                        android:id="@+id/dividerAfterRows"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:background="@color/gray_hint"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvEmployeeShift" />

                    <!-- Punch in / punch out stat tiles -->

                    <TextView
                        android:id="@+id/punchInLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:id="@+id/tvPunchInTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_stat_tile"
                        android:backgroundTint="@color/primary_text_color"
                        android:padding="10dp"
                        android:text="Punch In : "
                        android:textColor="@color/progress_fill"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/tvPunchOutTime"
                        app:layout_constraintHorizontal_chainStyle="spread"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dividerAfterRows" />

                    <TextView
                        android:id="@+id/punchOutLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:id="@+id/tvPunchOutTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_stat_tile"
                        android:backgroundTint="@color/primary_text_color"
                        android:padding="10dp"
                        android:text="Punch Out : "
                        android:textColor="@color/SickLeave"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvPunchInTime"
                        app:layout_constraintTop_toTopOf="@id/tvPunchInTime" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Shimmer for leave chart -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/leavePieChartShimmer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/employeeCardShimmer">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/text_primary"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <View
                            android:layout_width="160dp"
                            android:layout_height="18dp"
                            android:background="@color/primary_text_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_marginTop="16dp"
                            android:background="@color/primary_text_color" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- Leave statistics card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/leavePieChartContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/text_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/employeeCard"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="Leave Statistics"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/leavePieChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/includedBirthdayCarousel"
                layout="@layout/layout_dashboard_birthday_carousel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/leavePieChartContainer" />

            <View
                android:id="@+id/blurOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#80000000"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ProgressBar
                android:id="@+id/loader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>