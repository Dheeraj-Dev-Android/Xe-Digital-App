<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.vms.VmsFragment">

    <!-- Chip navigation sits outside the scroll, always visible -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/navigationChipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        app:chipSpacingHorizontal="4dp"
        app:chipSpacingVertical="4dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/preApprovedVisitorChip"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Pre-Approved Visitors"
            android:textColor="@color/avatar_text"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/chip_background"
            app:chipIcon="@drawable/ic_add_person"
            app:chipStrokeColor="@color/_000000"
            app:chipStrokeWidth="1dp"
            app:iconStartPadding="2dp"
            app:rippleColor="@color/_000000" />

        <com.google.android.material.chip.Chip
            android:id="@+id/checkVisitorsChip"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Check In Visitors"
            android:textColor="@color/avatar_text"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/chip_background"
            app:chipIcon="@drawable/ic_check_in"
            app:chipStrokeColor="@color/_000000"
            app:chipStrokeWidth="1dp"
            app:iconStartPadding="2dp"
            app:rippleColor="@color/avatar_text" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Divider replaces the unnecessary MaterialCardView wrapper -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/avatar_text" />

    <!-- FrameLayout lets loading/empty/list overlap correctly -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/VisitorsListRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F5F5F5"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:padding="16dp" />

        </androidx.core.widget.NestedScrollView>

        <!-- Loading indicator, centered in the remaining space -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/loadingProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/colorPrimary"
            app:indicatorSize="48dp"
            app:trackColor="@color/avatar_text"
            app:trackCornerRadius="4dp"
            app:trackThickness="4dp" />

        <!-- Empty state, centered in the remaining space -->
        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:contentDescription="No visitors found"
                android:src="@drawable/ic_empty_state" />

            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No Visitors Found"
                android:textColor="@color/purple_700"
                android:textSize="18sp" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>