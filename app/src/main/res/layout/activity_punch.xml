<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:fontFamily="@font/quicksand_font_family"
    tools:context=".activity.PunchActivity">

    <!-- ===== TOP HEADER MODULE ===== -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Top row: icon · divider · label · spacer · punch badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Clock/punch icon -->
            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Attendance clock icon"
                android:gravity="center"
                android:text="🕐"
                android:textSize="18sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="10dp"
                android:background="#2A2A3A" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:text="ATTENDANCE SYSTEM"
                android:textColor="#4A4A6A"
                android:textSize="10sp" />

            <!-- Live clock display -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#12121C"
                app:cardCornerRadius="6dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A3A"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/clockText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="09:41 AM"
                    android:textColor="#5B5BFF"
                    android:textSize="11sp"
                    tools:text="09:41 AM" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:lineSpacingExtra="2dp"
            android:text="Face\nAttendance"
            android:textColor="#EEEEF8"
            android:textSize="30sp" />

        <!-- Accent line -->
        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            android:background="#5B5BFF" />

        <!-- Date row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="Monday, 23 April 2026"
                android:textColor="#4A4A6A"
                android:textSize="11sp"
                tools:text="Monday, 23 April 2026" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== CAMERA MODULE (Circle — matches FaceLogin) ===== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cameraCard"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:cardBackgroundColor="#12121C"
        app:cardCornerRadius="140dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:strokeColor="#5B5BFF"
        app:strokeWidth="2dp">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Camera preview for face detection" />

        <app.xedigital.ai.utills.FaceOverlayView
            android:id="@+id/faceOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Face detection overlay" />

        <!-- Scanner line (green for attendance context vs indigo for login) -->
        <View
            android:id="@+id/scannerLine"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#4CAF50"
            android:visibility="gone" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Invisible guide view (same size as camera circle) for animator height reference -->
    <View
        android:id="@+id/faceGuide"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:alpha="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <!-- Corner scan decorators (visual only) -->
    <View
        android:layout_width="24dp"
        android:layout_height="3dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:alpha="0.6"
        android:background="#5B5BFF"
        app:layout_constraintStart_toStartOf="@id/cameraCard"
        app:layout_constraintTop_toTopOf="@id/cameraCard" />

    <View
        android:layout_width="3dp"
        android:layout_height="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:alpha="0.6"
        android:background="#5B5BFF"
        app:layout_constraintEnd_toEndOf="@id/cameraCard"
        app:layout_constraintTop_toTopOf="@id/cameraCard" />

    <!-- ===== STATUS MODULE ===== -->
    <LinearLayout
        android:id="@+id/statusModule"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toTopOf="@id/punchStatusCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cameraCard">

        <!-- Live indicator + label -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/shape_pulse_dot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.25"
                android:text="SCANNING"
                android:textColor="#5B5BFF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Main instruction / status text — same id CaptureText as original Java expects -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#12121C"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A5B5BFF"
            app:strokeWidth="1dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/CaptureText"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/quicksand_font_family"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:text="Position your face\nwithin the circle"
                android:textColor="#EEEEF8"
                android:textSize="17sp"
                android:textStyle="bold" />

        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ===== PUNCH STATUS BADGE (unique to PunchActivity) ===== -->
    <!--
        Shows PUNCH IN / PUNCH OUT context so user knows what action is being recorded.
        Java can toggle punchTypeLabel text and punchTypeCard stroke color accordingly.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/punchStatusCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        app:cardBackgroundColor="#12121C"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/footerText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#5B5BFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <!-- Colored dot: green = punch-in, red = punch-out (set from Java) -->
            <View
                android:id="@+id/punchDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/shape_pulse_dot" />

            <TextView
                android:id="@+id/punchTypeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:text="PUNCH IN"
                android:textColor="#4CAF50"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ===== FOOTER MODULE ===== -->
    <TextView
        android:id="@+id/footerText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="48dp"
        android:layout_marginBottom="36dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Your attendance is being recorded\nsecurely and in real time."
        android:textColor="#3A3A5A"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== LOADING OVERLAY (matches FaceLogin panel) ===== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/loadingPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:cardBackgroundColor="#E6000000"
        app:cardElevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Spinner card (same style as FaceLogin) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="88dp"
                android:layout_height="88dp"
                app:cardBackgroundColor="#12121C"
                app:cardCornerRadius="44dp"
                app:cardElevation="0dp"
                app:strokeColor="#5B5BFF"
                app:strokeWidth="1dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:contentDescription="Loading indicator"
                    android:indeterminate="true"
                    app:indicatorColor="#5B5BFF"
                    app:indicatorSize="44dp"
                    app:trackColor="#1A5B5BFF"
                    app:trackThickness="4dp" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:text="Recording Attendance..."
                android:textColor="#EEEEF8"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="Please hold still"
                android:textColor="#4A4A6A"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>