<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->

    <!-- Custom Styles -->
    <style name="CircularImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Text Styles -->

    <!-- Chip Styles -->

    <style name="TextInputLayoutHint" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/purple_700</item>
    </style>

    <style name="NavigationViewTextAppearance" parent="TextAppearance.AppCompat">
        <item name="fontFamily">@font/quicksand_font_family</item>
    </style>

    <!--Claim Details-->
    <!-- Section Title Style -->

    <!-- Table Row Style -->

    <!-- Label Style -->

    <!-- Value Style -->

    <style name="ClaimDetailTextWithIcon">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/primary_text_color</item>
        <item name="android:drawablePadding">12dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="ThemeOverlay.MaterialComponents.MaterialAlertDialog" parent="@style/ThemeOverlay.MaterialComponents.Dialog.Alert">
        <!--            <item name="colorAccent">@color/</item>-->
        <item name="android:buttonBarPositiveButtonStyle">@style/MyPositiveButton</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/MyNegativeButton</item>
        <item name="android:buttonBarNeutralButtonStyle">@style/MyNeutralButton</item>
    </style>

    <style name="MyPositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/approved_status_color</item>
    </style>

    <style name="MyNegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/rejected_status_color</item>
    </style>

    <style name="MyNeutralButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/rejected_status_color</item>
    </style>

    <style name="Theme.XEDigital.NoActionBar.Starting">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/color_white</item>
    </style>

    <style name="AppTheme.CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ExtraRoundedCorners</item>
        <item name="dialogPreferredPadding">0dp</item>
    </style>

    <style name="ExtraRoundedCorners">
        <item name="cornerSize">28dp</item>
    </style>


</resources>